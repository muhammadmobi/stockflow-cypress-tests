{
  "name": "stockflow-cypress-tests",
  "version": "1.0.0",
  "scripts": {
    "clean-reports": "rimraf cypress/results cypress/screenshots mochawesome.json mochawesome-report",
    "cy:debug": "cypress open --browser chrome --config watchForFileChanges=true",
    "cy:open": "cypress open",
    "cy:open:smoke": "cypress open --env grepTags=@smoke",
    "cy:open:regression": "cypress open --env grepTags=@regression",
    "cy:run": "cypress run --browser chrome",
    "cy:run:report": "cypress run --reporter cypress-mochawesome-reporter",
    "cy:run:single": "cypress run --browser chrome --spec",
    "cy:run:smoke": "cypress run --browser chrome --spec \"cypress/e2e\" --env grepTags=@smoke",
    "merge-reports": "npx mochawesome-merge cypress/results/*.json > mochawesome.json",
    "generate-report": "npx marge mochawesome.json --reportDir mochawesome-report --inline",
    "serve-report": "http-server mochawesome-report",
    "smoke-tests": "npm-run-all clean-reports cy:run:smoke merge-reports generate-report serve-report --continue-on-error"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@nestjs/axios": "^4.0.0",
    "@nestjs/swagger": "^11.1.3",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "http-server": "^14.1.1",
    "rimraf": "^6.0.1",
    "swagger-ui-express": "^5.0.1",
    "zebra-browser-print-wrapper-global": "^0.1.3"
  },
  "devDependencies": {
    "@bahmutov/cy-grep": "^2.1.0",
    "@cypress/xpath": "^2.0.3",
    "@faker-js/faker": "^9.8.0",
    "@testing-library/cypress": "^10.1.0",
    "cypress": "^15.13.0",
    "cypress-file-upload": "^5.0.8",
    "cypress-map": "^1.56.0",
    "cypress-mochawesome-reporter": "^4.0.2",
    "cypress-multi-reporters": "^2.0.5",
    "cypress-real-events": "^1.15.0",
    "cypress-xpath": "^2.0.1",
    "mochawesome-merge": "^5.0.0",
    "npm-run-all": "^4.1.5"
  }
}
